  "snipforge": "command",
  "title": "Curl: POST with Bearer token",
  "body": "curl -X POST {{url}} \\\n  -H \"Authorization: Bearer {{token}}\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '{{json data}}'",
  "description": "POST with JWT/Bearer authentication",
