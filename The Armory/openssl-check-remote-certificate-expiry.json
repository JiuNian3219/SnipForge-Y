  "snipforge": "command",
  "title": "OpenSSL: Check remote certificate expiry",
  "body": "echo | openssl s_client -connect {{domain}}:443 2>/dev/null | openssl x509 -noout -dates",
  "description": "Check expiration dates of remote server's certificate",
