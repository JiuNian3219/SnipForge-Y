  "snipforge": "command",
  "title": "n8n API: Create new workflow",
  "body": "curl -X POST \"{{n8n-url}}/api/v1/workflows\" \\\n  -H \"X-N8N-API-KEY: {{api-key}}\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\n    \"name\": \"{{workflow-name}}\",\n    \"nodes\": [],\n    \"connections\": {},\n    \"active\": false\n  }'",
  "description": "Create new workflow via API - useful for programmatic workflow creation (docs.n8n.io/api/api-reference/)",
  "tags": [
    "n8n",
    "api",
    "curl"
