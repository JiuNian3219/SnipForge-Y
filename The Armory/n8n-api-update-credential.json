  "snipforge": "command",
  "title": "n8n API: Update credential",
  "body": "curl -X PATCH \"{{n8n-url}}/api/v1/credentials/{{credential-id}}\" \\\n  -H \"X-N8N-API-KEY: {{api-key}}\" \\\n  -H \"Content-Type: application/json\" \\\n  -d '{\"name\": \"{{new-name}}\"}'",
  "description": "Update credential properties - modify credential configuration (docs.n8n.io/api/api-reference/)",
  "tags": [
    "n8n",
    "api",
    "curl"
  ],
