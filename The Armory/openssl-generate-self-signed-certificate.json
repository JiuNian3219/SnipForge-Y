{
  "snipforge": "command",
  "title": "OpenSSL: Generate self-signed certificate",
  "body": "openssl req -x509 -newkey rsa:4096 -keyout {{key.key}} -out {{cert.crt}} -days {{365}} -nodes -subj \"/CN={{domain}}\"",
  "description": "Create self-signed SSL certificate for testing (not for production)",
  "tags": [
    "openssl",
    "ssl"
  ],
