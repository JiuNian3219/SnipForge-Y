{
  "snipforge": "command",
  "title": "OpenSSL: Generate CSR",
  "body": "openssl req -new -newkey rsa:2048 -nodes -keyout {{key.key}} -out {{request.csr}} -subj \"/CN={{domain}}/O={{Organization}}\"",
  "description": "Generate Certificate Signing Request for CA",
